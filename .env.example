# E*TRADE app consumer credentials.
# Get these from https://us.etrade.com/etx/ris/apikey after enrolling in
# E*TRADE's Developer Platform. They are NOT the same as your login credentials.
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# The briefing pipeline reads these via scripts/etrade_auth.py.
ETRADE_CONSUMER_KEY=your_etrade_consumer_key_here
ETRADE_CONSUMER_SECRET=your_etrade_consumer_secret_here
